# Copy to .env and fill in real values. Do NOT commit .env.
# Keys use underscores (valid shell/PowerShell variable names).
# scripts/load-env.sh and your PowerShell profile load this file.

# --- Datadog ---
DD_SITE=us5.datadoghq.com          # your Datadog site (e.g. datadoghq.com, us5.datadoghq.com)
DD_API_KEY=your-datadog-api-key    # 32-char API key
DD_APP_KEY=your-datadog-app-key    # application key (ddapp_...)

# --- AWS ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
